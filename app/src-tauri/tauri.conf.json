{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mite",
  "version": "0.0.0",
  "identifier": "black.jessica.mite",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mite",
        "width": 1280,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jssblck/mite/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4MjNERDFDNDNBOEI3QjQKUldTMHQ2aERITjBqZUNKT2lPVXlaN3lJc1FYcGJqbi9vdXV3eEhGSnVseXN1eDc2YVF2SWltUUkK"
    }
  }
}
