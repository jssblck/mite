---
import { GITHUB_URL, RELEASES_URL } from "../data/sentences";
import Icon from "./Icon.astro";
import MiteWord from "./MiteWord.astro";
import SectionHead from "./SectionHead.astro";

// The desktop app flow, shown as a small window mock on the right.
const steps = [
  {
    title: "Run the installer",
    body: "The app walks you through getting set up.",
  },
  {
    title: "Pick a window",
    body: "Choose your game, visual novel, or app from a live preview grid.",
  },
  {
    title: "Read",
    body: "Hover any word for its reading, dictionary form, and meaning.",
  },
];
---

<section id="start" class="start">
  <div class="container start-grid">
    <div>
      <SectionHead>
        <span slot="title">Install it and read.</span>
      </SectionHead>
      <div class="start-cta">
        <a href={RELEASES_URL} class="btn btn-primary" target="_blank" rel="noreferrer">
          <Icon name="download" size={16} /> Get <MiteWord />
        </a>
        <a href={GITHUB_URL} class="btn btn-ghost" target="_blank" rel="noreferrer">
          <Icon name="github" size={16} /> View on GitHub
        </a>
      </div>
      <p class="start-reqs">
        Requirements: Windows 10 or 11. An NVIDIA GPU is recommended for the
        fastest path; a CPU fallback works without one.
      </p>
    </div>

    <div class="app-card">
      <div class="app-bar">
        <span class="capture-dot"></span>
        <span class="capture-dot"></span>
        <span class="capture-dot"></span>
        <span class="mono app-label">Mite</span>
      </div>
      <ol class="app-steps">
        {
          steps.map((step, i) => (
            <li class="app-step">
              <span class="app-step-num mono">{i + 1}</span>
              <div class="app-step-text">
                <p class="app-step-title">{step.title}</p>
                <p class="app-step-body">{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .start {
    scroll-margin-top: 6rem;
    border-top: 1px solid var(--color-line);
    background: var(--color-bg-2);
    padding-block: 5rem;
  }
  .start-grid {
    display: grid;
    gap: 3rem;
  }
  .start-cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .start-reqs {
    margin: 1.5rem 0 0;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .app-card {
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid var(--color-line);
    background: var(--color-bg);
  }
  .app-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--color-line);
    padding: 0.625rem 1rem;
  }
  .app-label {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-faint);
  }
  .app-steps {
    list-style: none;
    margin: 0;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .app-step {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }
  .app-step-num {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 99px;
    border: 1px solid color-mix(in oklch, var(--color-accent) 45%, transparent);
    background: color-mix(in oklch, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    font-size: 0.8125rem;
    font-weight: 600;
  }
  .app-step-text {
    margin-top: 0.1rem;
  }
  .app-step-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .app-step-body {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  @media (min-width: 640px) {
    .start {
      padding-block: 7rem;
    }
  }
  @media (min-width: 1024px) {
    .start-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: center;
    }
  }
</style>
