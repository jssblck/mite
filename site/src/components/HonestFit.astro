---
import Icon from "./Icon.astro";
import MiteTerm from "./MiteTerm.astro";
import SectionHead from "./SectionHead.astro";

const reachFor = [
  "Native games and visual novels",
  "Manga and comic readers",
  "Subtitles and video, paused or live",
  "Any Windows app a browser cannot touch",
];
---

<section id="fit" class="container section fit">
  <SectionHead>
    <span slot="title">Where <MiteTerm /> fits, and where it does not.</span>
    <MiteTerm /> is built for one job and points you elsewhere for the rest.
  </SectionHead>

  <div class="fit-grid">
    <div class="fit-card">
      <div class="fit-card-head">
        <Icon name="eye" size={20} color="var(--color-accent)" />
        <h3 class="fit-card-title">Reach for <MiteTerm /></h3>
      </div>
      <ul class="fit-list">
        {
          reachFor.map((item) => (
            <li>
              <span class="fit-bullet" />
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="fit-card">
      <div class="fit-card-head">
        <Icon name="arrow-up-right" size={20} color="var(--color-muted)" />
        <h3 class="fit-card-title">Reach for your browser</h3>
      </div>
      <p class="fit-body">
        For ordinary web pages, browser-native tools like Yomitan and 10ten are
        the better fit: they read the page's own text directly. <MiteTerm />'s
        niche is everything outside the browser.
      </p>
      <p class="fit-fine">
        <MiteTerm /> is Windows-first and optimized for NVIDIA hardware. It falls
        back gracefully to CPU, but the reference experience is a recent NVIDIA GPU.
      </p>
    </div>
  </div>
</section>

<style>
  .section {
    scroll-margin-top: 6rem;
    padding-block: 5rem;
  }
  .fit-grid {
    margin-top: 3rem;
    display: grid;
    gap: 1rem;
  }
  .fit-card {
    border-radius: 0.75rem;
    border: 1px solid var(--color-line);
    background: var(--color-bg-2);
    padding: 1.75rem;
  }
  .fit-card-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .fit-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }
  .fit-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    color: var(--color-ink-2);
  }
  .fit-list li {
    display: flex;
    gap: 0.75rem;
  }
  .fit-list li + li {
    margin-top: 0.75rem;
  }
  .fit-bullet {
    margin-top: 0.5rem;
    height: 0.375rem;
    width: 0.375rem;
    flex: none;
    border-radius: 99px;
    background: var(--color-accent);
  }
  .fit-body {
    margin: 1.25rem 0 0;
    color: var(--color-ink-2);
  }
  .fit-fine {
    margin: 1rem 0 0;
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  @media (min-width: 640px) {
    .section {
      padding-block: 7rem;
    }
  }
  @media (min-width: 768px) {
    .fit-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
