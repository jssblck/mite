interface Props {
  name: IconName;
  /* Pixel size; sets width/height as real attributes so sizing never depends on
     scoped CSS reaching this child component's <svg>. */
  size?: number;
  /* Optional CSS color for the stroke (icons use currentColor); omit to inherit
     the surrounding text color. */
  color?: string;
  class?: string;
}

const { name, size = 20, color, class: className } = Astro.props;
const style = `flex:none${color ? `;color:${color}` : ""}`;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  style={style}
  aria-hidden="true"
  set:html={ICONS[name]}
/>
