---
import { HERO_SENTENCE, RELEASES_URL } from "../data/sentences";
import Icon from "./Icon.astro";
import MiteTerm from "./MiteTerm.astro";
import MiteWord from "./MiteWord.astro";
import OverlayLine from "./OverlayLine.astro";
---

<section class="hero">
  <div class="grid-bg hero-grid" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-copy">
      <h1 class="anim-rise hero-title">
        Read the Japanese in your games,<br />
        <span class="hero-title-strong">right where it appears.</span>
      </h1>
      <p class="anim-rise measure hero-lede" data-delay="1">
        <MiteTerm /> is a reading aid for learning Japanese. It reads the text on
        your screen (games, visual novels, anything Windows can show) and shows
        the reading and meaning of each word, right where you're looking. It runs
        locally in about 200ms, with no alt-tab to a dictionary.
      </p>
      <div class="anim-rise hero-cta" data-delay="2">
        <a href={RELEASES_URL} class="btn btn-primary" target="_blank" rel="noreferrer">
          Get <MiteWord /> <Icon name="arrow-right" size={16} />
        </a>
        <a href="#how" class="btn btn-ghost">See how it works</a>
      </div>
    </div>

    <div class="anim-rise hero-demo" data-delay="3">
      <figure class="capture">
        <div class="capture-frame">
          <div class="capture-clip">
            <div class="scanline" style="top: 3.5rem"></div>
          </div>
          <div class="capture-titlebar">
            <span class="capture-dot"></span>
            <span class="capture-dot"></span>
            <span class="capture-dot"></span>
            <span class="mono capture-window">window</span>
            <span class="mono capture-status">
              <span class="capture-status-dot"></span>
              MITE / READING
            </span>
          </div>
          <div class="capture-stage">
            <div class="detect-box">
              <OverlayLine sentence={HERO_SENTENCE} />
            </div>
          </div>
        </div>
        <figcaption class="capture-caption">
          <Icon name="mouse-pointer-2" size={14} color="var(--color-accent)" />
          Hover or focus any word
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-line);
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    padding-block: 5rem 4rem;
  }
  .hero-copy {
    max-width: 48rem;
    margin-inline: auto;
    text-align: center;
  }
  .hero-title {
    font-size: clamp(1.75rem, 8vw, 4.75rem);
    font-weight: 800;
  }
  .hero-title-strong {
    color: var(--color-ink);
  }
  .hero-lede {
    margin: 1.5rem auto 0;
    font-size: 1.125rem;
    text-wrap: balance;
    color: var(--color-ink-2);
  }
  .hero-cta {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .hero-demo {
    margin: 3.5rem auto 0;
    max-width: 56rem;
  }

  @media (min-width: 640px) {
    .hero-inner {
      padding-block: 7rem 6rem;
    }
    .hero-lede {
      font-size: 1.25rem;
    }
  }

  /* ---- capture demo frame ---- */
  .capture {
    margin: 0;
  }
  .capture-frame {
    position: relative;
    border: 1px solid var(--color-line);
    border-radius: 0.9rem;
    background:
      radial-gradient(
        120% 80% at 80% 0%,
        oklch(0.27 0.03 256 / 0.6),
        transparent 60%
      ),
      radial-gradient(
        90% 90% at 0% 100%,
        oklch(0.24 0.04 280 / 0.45),
        transparent 55%
      ),
      linear-gradient(160deg, oklch(0.2 0.012 256), oklch(0.165 0.01 256));
    box-shadow:
      0 1px 0 0 oklch(0.99 0 0 / 0.05) inset,
      0 40px 80px -40px oklch(0 0 0 / 0.8);
  }

  /* Clip layer for the scanline only, so definition popups can still float
     above the frame's top edge like a real overlay. */
  .capture-clip {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    pointer-events: none;
  }

  .capture-titlebar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 2.25rem;
    padding-inline: 0.85rem;
    border-bottom: 1px solid var(--color-line);
    background: oklch(0.18 0.008 256 / 0.7);
  }
  .capture-window {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-faint);
  }
  .capture-status {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }
  .capture-status-dot {
    display: inline-block;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 99px;
    background: var(--color-accent);
  }

  .capture-stage {
    position: relative;
    display: flex;
    min-height: 17rem;
    align-items: flex-end;
    justify-content: center;
    padding: 2.5rem 1.5rem 3rem;
  }
  @media (min-width: 640px) {
    .capture-stage {
      padding-inline: 3rem;
    }
  }

  /* The OCR detection box drawn around a recognized line: a faint bounding
     rectangle with accent corner brackets, like a crop/selection reticle. */
  .detect-box {
    position: relative;
    padding: 0.5rem 1.1rem 0.7rem;
    border: 1px solid color-mix(in oklch, var(--color-line-2) 70%, transparent);
    border-radius: 10px;
  }
  .detect-box::before,
  .detect-box::after {
    content: "";
    position: absolute;
    width: 13px;
    height: 13px;
    pointer-events: none;
  }
  .detect-box::before {
    top: -1px;
    left: -1px;
    border-top: 2px solid var(--color-accent);
    border-left: 2px solid var(--color-accent);
    border-top-left-radius: 10px;
  }
  .detect-box::after {
    right: -1px;
    bottom: -1px;
    border-right: 2px solid var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
    border-bottom-right-radius: 10px;
  }

  /* "scanning" reticle line that sweeps once on load */
  .scanline {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-accent) 50%,
      transparent
    );
    opacity: 0;
    filter: blur(0.4px);
  }

  .capture-caption {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  @media (prefers-reduced-motion: no-preference) {
    @keyframes sweep {
      0% {
        opacity: 0;
        transform: translateY(2.25rem);
      }
      8% {
        opacity: 0.9;
      }
      92% {
        opacity: 0.9;
      }
      100% {
        opacity: 0;
        transform: translateY(min(46vh, 22rem));
      }
    }
    .scanline {
      animation: sweep 2.6s var(--ease-out) 0.5s 1 both;
    }
  }
</style>
