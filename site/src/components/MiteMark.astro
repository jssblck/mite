---
/*
  Mite mark: an OCR focus-reticle. Corner brackets framing a detected line, with
  the accent tick standing in for the moment of recognition. Quiet, exact,
  instrument-like: the brand in one glyph.
*/
interface Props {
  /* Any CSS length (e.g. "1.45em", "1rem"); sets width/height as real attributes
     so sizing does not depend on scoped CSS reaching this child component. */
  size?: string;
  /* Optional CSS color for the corner brackets (they use currentColor); omit to
     inherit the surrounding text color. */
  color?: string;
  class?: string;
  title?: string;
}
const { size = "1em", color, class: className, title = "Mite" } = Astro.props;
const style = `flex:none${color ? `;color:${color}` : ""}`;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  role="img"
  aria-label={title}
  style={style}
  xmlns="http://www.w3.org/2000/svg"
>
  <g
    stroke="currentColor"
    stroke-width="1.7"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M3 7.5V4.5C3 3.67 3.67 3 4.5 3H7.5"></path>
    <path d="M16.5 3H19.5C20.33 3 21 3.67 21 4.5V7.5"></path>
    <path d="M21 16.5V19.5C21 20.33 20.33 21 19.5 21H16.5"></path>
    <path d="M7.5 21H4.5C3.67 21 3 20.33 3 19.5V16.5"></path>
  </g>
  {/* detected line + recognition tick */}
  <rect x="7" y="11" width="10" height="2" rx="1" fill="currentColor" opacity="0.5"></rect>
  <rect x="7" y="11" width="4" height="2" rx="1" fill="var(--color-accent)"></rect>
</svg>
