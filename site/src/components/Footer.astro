---
import { GITHUB_URL, RELEASES_URL } from "../data/sentences";
import MiteMark from "./MiteMark.astro";
import MiteTerm from "./MiteTerm.astro";
import Wordmark from "./Wordmark.astro";

type Link = { href: string; label: string; ext?: boolean };

const PRODUCT: Link[] = [
  { href: "/#how", label: "How it works" },
  { href: "/#why", label: "Accuracy" },
  { href: "/#grammar", label: "Grammar" },
  { href: "/#fit", label: "Honest fit" },
  { href: "/faq", label: "FAQ" },
];
const PROJECT: Link[] = [
  { href: GITHUB_URL, label: "GitHub", ext: true },
  { href: RELEASES_URL, label: "Releases", ext: true },
  { href: "/#start", label: "Get started" },
];
const CREDITS = ["JMdict", "Lindera", "PP-OCRv5", "ONNX Runtime"];

const columns: { title: string; links: Link[] }[] = [
  { title: "Product", links: PRODUCT },
  { title: "Project", links: PROJECT },
];
---

<footer class="site-footer">
  <div class="container footer-pad">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="brand" aria-label="Mite home">
          <Wordmark />
        </a>
        <p class="footer-blurb">
          A reading aid for learning Japanese, right where it appears: in
          games, visual novels, and everything else on screen.
        </p>
      </div>

      <div class="footer-cols">
        {
          columns.map((col) => (
            <div>
              <h4 class="footer-col-title">{col.title}</h4>
              <ul class="footer-col-list">
                {col.links.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      {...(l.ext
                        ? { target: "_blank", rel: "noreferrer" }
                        : {})}
                    >
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
        <div>
          <h4 class="footer-col-title">Built on</h4>
          <ul class="footer-col-list footer-credits">
            {CREDITS.map((c) => <li>{c}</li>)}
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-license">
        <MiteMark size="1rem" />
        <span><MiteTerm />: open source, licensed AGPL-3.0.</span>
      </p>
      <p class="footer-fine">
        Dictionary data from JMdict. Sample Japanese on this site is original and
        illustrative.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-line);
  }
  .footer-pad {
    padding-block: 3.5rem;
  }
  .brand {
    font-size: 1.125rem;
  }
  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .footer-brand {
    max-width: 20rem;
  }
  .footer-blurb {
    margin: 1rem 0 0;
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.5rem;
  }
  .footer-col-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }
  .footer-col-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    font-size: 0.875rem;
  }
  .footer-col-list li + li {
    margin-top: 0.625rem;
  }
  .footer-col-list a {
    color: var(--color-muted);
    transition: color 0.16s var(--ease-out);
  }
  .footer-col-list a:hover {
    color: var(--color-ink);
  }
  .footer-credits {
    color: var(--color-muted);
  }
  .footer-bottom {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid var(--color-line);
    padding-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  .footer-license {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }
  .footer-fine {
    margin: 0;
    color: var(--color-faint);
  }

  @media (min-width: 640px) {
    .footer-cols {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .footer-bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }
  }
</style>
